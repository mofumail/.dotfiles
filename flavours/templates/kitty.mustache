# ── Font ──────────────────────────────────────────────
font_family      JetBrainsMono Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        12.0

# ── Cursor ────────────────────────────────────────────
cursor_shape          beam
cursor_beam_thickness 1.5
cursor_blink_interval 0.5

# ── Window ────────────────────────────────────────────
background_opacity 0.55
window_padding_width 12
confirm_os_window_close 0
remember_window_size no
initial_window_width  120c
initial_window_height 36c

# ── Tab bar ───────────────────────────────────────────
tab_bar_edge        bottom
tab_bar_style       powerline
tab_powerline_style slanted
active_tab_font_style   bold
inactive_tab_font_style normal

# ── URL handling ──────────────────────────────────────
url_style curly
detect_urls yes

# ── Bell ──────────────────────────────────────────────
enable_audio_bell no

# ── Theme ({{scheme-name}}) ────────────────────────────
foreground           #{{base05-hex}}
background           #{{base00-hex}}
selection_foreground #{{base00-hex}}
selection_background #{{base06-hex}}
cursor               #{{base06-hex}}
cursor_text_color    #{{base00-hex}}
url_color            #{{base0D-hex}}

# Tab bar colors
active_tab_foreground   #{{base00-hex}}
active_tab_background   #{{base0D-hex}}
inactive_tab_foreground #{{base05-hex}}
inactive_tab_background #{{base01-hex}}
tab_bar_background      #{{base00-hex}}

# Normal colors
color0  #{{base00-hex}}
color1  #{{base08-hex}}
color2  #{{base0B-hex}}
color3  #{{base0A-hex}}
color4  #{{base0D-hex}}
color5  #{{base0E-hex}}
color6  #{{base0C-hex}}
color7  #{{base05-hex}}

# Bright colors
color8  #{{base03-hex}}
color9  #{{base08-hex}}
color10 #{{base0B-hex}}
color11 #{{base0A-hex}}
color12 #{{base0D-hex}}
color13 #{{base0E-hex}}
color14 #{{base0C-hex}}
color15 #{{base07-hex}}

# Extended colors (marks)
mark1_foreground #{{base00-hex}}
mark1_background #{{base0D-hex}}
mark2_foreground #{{base00-hex}}
mark2_background #{{base0E-hex}}
mark3_foreground #{{base00-hex}}
mark3_background #{{base0C-hex}}
